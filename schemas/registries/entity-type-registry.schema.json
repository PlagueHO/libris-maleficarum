{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libris-maleficarum.dev/schemas/registries/entity-type-registry.schema.json",
  "title": "Entity Type Registry",
  "description": "Canonical entity type registry for Libris Maleficarum.",
  "type": "array",
  "items": {
    "$ref": "#/$defs/entityTypeConfig"
  },
  "$defs": {
    "propertyFieldValidation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "boolean"
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        },
        "pattern": {
          "type": "string"
        }
      }
    },
    "propertyFieldSchema": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "label",
        "type"
      ],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z][a-zA-Z0-9]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "text",
            "textarea",
            "integer",
            "decimal",
            "tagArray",
            "date",
            "datetime",
            "time"
          ]
        },
        "placeholder": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "maxLength": {
          "type": "integer",
          "minimum": 1
        },
        "validation": {
          "$ref": "#/$defs/propertyFieldValidation"
        }
      }
    },
    "entityTypeConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "label",
        "description",
        "category",
        "icon",
        "schemaVersion",
        "suggestedChildren"
      ],
      "properties": {
        "type": {
          "type": "string",
          "pattern": "^[A-Z][a-zA-Z0-9]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": [
            "Geography",
            "Characters & Factions",
            "Events & Quests",
            "Items",
            "Campaigns",
            "Containers",
            "Other"
          ]
        },
        "icon": {
          "type": "string",
          "pattern": "^[A-Z][a-zA-Z0-9]*$"
        },
        "schemaVersion": {
          "type": "integer",
          "minimum": 1
        },
        "suggestedChildren": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z][a-zA-Z0-9]*$"
          }
        },
        "canBeRoot": {
          "type": "boolean"
        },
        "propertySchema": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/propertyFieldSchema"
          }
        }
      }
    }
  }
}
